{
  "name": "@juandinella/audio-bands",
  "version": "0.4.7",
  "description": "Headless browser audio analysis. Get bass/mid/high bands from music or mic, with an optional React hook.",
  "keywords": [
    "react",
    "hook",
    "audio",
    "web-audio",
    "frequency",
    "visualizer",
    "headless",
    "bass",
    "analyser"
  ],
  "author": "Juan Dinella",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/juandinella/audio-bands"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core-entry.d.ts",
      "import": "./dist/core-entry.js",
      "require": "./dist/core-entry.cjs"
    },
    "./react": {
      "types": "./dist/react-entry.d.ts",
      "import": "./dist/react-entry.js",
      "require": "./dist/react-entry.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "npm run build && vitest run",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "jsdom": "^27.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
