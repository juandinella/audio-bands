{
  "name": "@juandinella/audio-bands",
  "version": "0.1.0",
  "description": "Headless React hook for real-time audio frequency analysis. Get bass/mid/high bands from music or mic, without a renderer.",
  "keywords": [
    "react",
    "hook",
    "audio",
    "web-audio",
    "frequency",
    "visualizer",
    "headless",
    "bass",
    "analyser"
  ],
  "author": "Juan Dinella",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
