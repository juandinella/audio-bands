{
  "name": "@juandinella/audio-bands",
  "version": "0.6.1",
  "description": "Headless browser audio analysis. Get bass/mid/high bands from music or mic, with an optional React hook.",
  "keywords": [
    "react",
    "hook",
    "audio",
    "web-audio",
    "frequency",
    "visualizer",
    "headless",
    "bass",
    "analyser"
  ],
  "author": "Juan Dinella",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/juandinella/audio-bands"
  },
  "homepage": "https://github.com/juandinella/audio-bands#readme",
  "bugs": {
    "url": "https://github.com/juandinella/audio-bands/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core-entry.d.ts",
      "import": "./dist/core-entry.js",
      "require": "./dist/core-entry.cjs"
    },
    "./react": {
      "types": "./dist/react-entry.d.ts",
      "import": "./dist/react-entry.js",
      "require": "./dist/react-entry.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "npm run build && vitest run tests/package.test.ts tests/core.test.ts tests/react.test.ts",
    "test:browser": "npm run build && playwright test",
    "test:browser:serve": "vite --config tests/browser/vite.config.ts --host 127.0.0.1 --port 4173",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
